{
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@droidsolutions-oss/semantic-release-update-file": "^1.4.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@droidsolutions-oss/semantic-release-update-file",
        {
          "files": [
            {
              "path": [
                "solutions/dgt_validators/src/Other/Solution.xml"
              ],
              "type": "xml",
              "replacements": [
                {
                  "key": "Version",
                  "value": "${nextRelease.version}"
                }
              ]
            }
          ]
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": "solutions/dgt_validators/src/Other/Solution.xml",
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "msbuild solutions/dgt_validators/dgt_validators.cdsproj /restore /property:Configuration=Release"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "solutions/dgt_validators/bin/Release/dgt_validators.zip",
              "label": "DigitallValidators (${nextRelease.version})",
              "name": "DigitallValidators.zip"
            }
          ]
        }
      ]
    ]
  },
  "scripts": {
    "prepare": "husky"
  }
}
